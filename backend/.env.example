# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fretagru

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Integrações
AEGRO_API_URL=https://api.aegro.com.br
AEGRO_API_KEY=your-aegro-api-key

# Logs
LOG_LEVEL=INFO

# CORS
CORS_ORIGIN=http://localhost:3000
